# ---- moesekai v2 server configuration ----
# Copy to .env and fill in. Settings marked (seed) are written to the DB on
# first run only; afterward the admin UI is authoritative.

# --- Required ---
# Secret used to sign JWT session tokens. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string
# Master key for encrypting secret settings (LLM keys, backup credentials) at
# rest in SQLite. Without it, secrets cannot be stored. Keep it stable.
MOESEKAI_MASTER_KEY=change-me-too

# --- Server ---
PORT=9090
DB_PATH=./data/moesekai.db
DATA_DIR=./data
# Allowed origin for the console API (CORS). Set to your console URL in prod.
CONSOLE_ORIGIN=*
# Session lifetime in hours (default 168 = 7 days).
TOKEN_TTL_HOURS=168

# --- Initial admin (created only when no users exist) ---
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
# Or legacy-style: TRANSLATOR_ACCOUNTS=admin:pw,editor:pw2 (first is admin)

# --- LLM (seed) ---
LLM_TYPE=openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Upstream update detection (seed) ---
UPSTREAM_REPO=Team-Haruki/haruki-sekai-master
UPSTREAM_BRANCH=main
# Version detection URL. Empty uses the metadata.pjsk.moe mirror below; templates may
# use {repo} and {branch}, for example a jsDelivr GitHub CDN URL.
UPSTREAM_VERSION_URL=https://metadata.pjsk.moe/jp/versions/current_version.json
# Comma-separated custom fallbacks. GitHub Raw, Fastly, Gcore and jsDelivr
# rescue URLs are also appended automatically.
UPSTREAM_VERSION_FALLBACK_URL=https://raw.githubusercontent.com/{repo}/{branch}/versions/current_version.json
# Masterdata and scenario sources. Templates may use {repo} and {branch}.
UPSTREAM_JP_MASTERDATA_URL=https://metadata.pjsk.moe/jp/master
UPSTREAM_JP_MASTERDATA_FALLBACK_URL=https://raw.githubusercontent.com/{repo}/{branch}/master
UPSTREAM_CN_MASTERDATA_URL=https://metadata.pjsk.moe/cn/master
UPSTREAM_CN_MASTERDATA_FALLBACK_URL=https://sekaimaster-cn.exmeaning.com/master
# assets.unipjsk.com is primary because snowyassets.exmeaning.com currently
# returns HTTP 525. Leave a fallback empty unless another healthy mirror exists.
UPSTREAM_JP_ASSETS_URL=https://assets.unipjsk.com/ondemand
UPSTREAM_JP_ASSETS_FALLBACK_URL=
UPSTREAM_CN_ASSETS_URL=https://sekai-assets-bdf29c81.seiunx.net/cn-assets/ondemand
UPSTREAM_CN_ASSETS_FALLBACK_URL=
# Maximum concurrent upstream downloads (clamped to 1-12, default 4).
UPSTREAM_FETCH_CONCURRENCY=4
TRANSLATE_SCHEDULER_ENABLED=true
# Poll interval for current_version.json, in ms (default 1 hour).
UPSTREAM_POLL_MS=3600000
# Maintain a local git clone of the masterdata repo for sync work. Version
# detection uses UPSTREAM_VERSION_URL and backs off automatically on 429.
UPSTREAM_USE_GIT=false

# --- GitHub backup (seed) ---
# Repo URL may embed a token: https://x-access-token:TOKEN@github.com/owner/repo.git
GIT_PUSH_REPO_URL=
GIT_PUSH_BRANCH=backup-translations

# --- S3 backup (seed) ---
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ENDPOINT=https://s3.amazonaws.com
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# --- Search index refresh (ms) ---
SEARCH_INDEX_DEBOUNCE_MS=3600000
SEARCH_INDEX_REFRESH_MS=3600000
